body {
    font-family: Arial, sans-serif;
    background-color: #f2f2f2;
    margin: 0;
    padding: 40px;
}

.card {
    background-color: white;
    max-width: 600px;
    margin: auto;
    padding: 30px;
    border-radius: 12px;
    text-align: center;
}

h1 { 
    color: #222;
}

p {
    color: #444;
    line-height: 1.6;
}

img {
    width: 300px;
    max-width: 100%;
    border-radius: 10px;
    margin: 20px 0;
}
   
